# GitHub OAuth App credentials (Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must EXACTLY match the "Authorization callback URL" set on the OAuth App
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# The template repo you created and marked as a template, e.g.
#   TEMPLATE_OWNER=your-username
#   TEMPLATE_REPO=my-starter-template
TEMPLATE_OWNER=
TEMPLATE_REPO=

# Topic stamped on every repo created here, used to build the listing.
# Lowercase, hyphens allowed.
REPO_TOPIC=created-with-instigation
