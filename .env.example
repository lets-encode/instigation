# Public (client-visible) configuration for the static SPA. None of these are
# secret — the OAuth client secret lives only in the token broker (see broker/).
# All are read at build time via $env/dynamic/public.

# GitHub OAuth App client id (Settings > Developer settings > OAuth Apps).
# The app's "Authorization callback URL" must be <your-site-origin>/auth/callback
# (the SPA derives the redirect URI from its own origin).
PUBLIC_GITHUB_CLIENT_ID=

# Base URL of the deployed token broker (see broker/README.md), e.g.
#   https://lets-encode-broker.example.workers.dev
PUBLIC_OAUTH_BROKER_URL=

# The template repo new campaigns are stamped from.
PUBLIC_TEMPLATE_OWNER=
PUBLIC_TEMPLATE_REPO=

# Topic stamped on every repo created here, used to build the listing.
PUBLIC_REPO_TOPIC=created-with-instigation

# Which forge implementation to use (only 'github' is implemented today).
PUBLIC_FORGE=github

# mei-friend instance volunteers are handed off to for editing.
PUBLIC_MEI_FRIEND_URL=https://mei-friend.mdw.ac.at
